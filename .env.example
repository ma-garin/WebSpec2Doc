# OpenAI API キー（https://platform.openai.com/api-keys で取得）
OPENAI_API_KEY=your_api_key_here

# 使用モデル（省略時は gpt-5.4-mini）
# OPENAI_MODEL=gpt-5.4-mini

# ─── アプリ利用者認証・テナント（商用/共有サーバ展開向け） ───

# 認証モード: auto（既定: ユーザー作成後に自動でログイン必須化）/ required / off
# WEBSPEC2DOC_AUTH_MODE=auto

# 認証DBの場所（省略時 instance/auth.db）
# WEBSPEC2DOC_AUTH_DB=instance/auth.db

# セッション有効時間（時間、省略時 12）
# WEBSPEC2DOC_SESSION_HOURS=12

# HTTPS 終端の背後で運用する場合は 1 にして Secure クッキーを強制する
# WEBSPEC2DOC_SECURE_COOKIES=1

# Flask SECRET_KEY（省略時は instance/secret_key に自動生成・保存）
# WEBSPEC2DOC_SECRET_KEY=

# 共有サーバ展開時に許可するホスト名（カンマ区切り）。未設定ならローカルのみ
# WEBSPEC2DOC_TRUSTED_HOSTS=webspec2doc.internal

# ─── 利用ガバナンス（インスタンス全体の上書き。0 = 無制限） ───

# 1分あたりのAPIリクエスト上限（ユーザー/APIトークン単位）
# WEBSPEC2DOC_RATE_PER_MINUTE=120

# テナントあたりの月次クロール実行上限
# WEBSPEC2DOC_MONTHLY_CRAWLS=100

# テナントあたりの同時実行ジョブ上限
# WEBSPEC2DOC_CONCURRENT_JOBS=2
